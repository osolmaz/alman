---
// Scroll-driven demonstration framed as the Institut finally processing
// Mark Twain's 1880 complaint about German ("The Awful German Language").
// All authored copy lives in scrolly-content.ts, which also generates the
// linear Markdown transcript used by the machine-readable site editions.
import worldMap from "../assets/world-map.svg?raw";
import {
  scrollyContent as content,
} from "../lib/scrolly-content";
import { richTextHtml } from "../lib/scrolly-html";
import ScrollyStep from "./ScrollyStep.astro";
import ScrollyTransformTable from "./ScrollyTransformTable.astro";
---

<section class="scrolly" id="demo" data-step="0" data-stage="f1">
  <header class="scrolly-lead">
    <p class="kicker">{content.lead.kicker}</p>
    <h2>{content.lead.title}</h2>
    <p class="sub">{content.lead.subtitle}</p>
  </header>

  <div class="scrolly-body">
    <!-- Group: the Twain case file, sheet 1 -->
    <div class="group">
      <ScrollyStep step={0} />
      <div class="stage-col">
        <div class="stage-sticky">
          <div class="stage-card stage-f1" data-from="0" data-to="1">
            <div class="card-head">
              <span>{content.caseFile.head.left}</span>
              <span>{content.caseFile.head.right}</span>
            </div>
            <p
              class="file-meta"
              set:html={content.caseFile.meta.map(richTextHtml).join("<br />")}
            />
            <blockquote class="file-quote">{content.caseFile.quote}</blockquote>
            <p
              class="file-attrib"
              set:html={richTextHtml(content.caseFile.attribution)}
            />
            <div class="file-annex" data-at="1">
              <p class="annex-label">{content.caseFile.annexLabel}</p>
              <div class="annex-dialogue">
                {
                  content.caseFile.dialogue.map((line) => (
                    <p>
                      <span class="speaker">{line.speaker}</span> {line.text}
                    </p>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="group-steps">
        <ScrollyStep step={1} />
      </div>
    </div>

    <!-- Group: exhibit — the gender inventory -->
    <div class="group">
      <ScrollyStep step={2} />
      <div class="stage-col">
        <div class="stage-sticky">
          <div class="stage-card stage-f2">
            <div class="card-head">
              <span>{content.inventory.head.left}</span>
              <span>{content.inventory.head.right}</span>
            </div>
            <table class="inv-table">
              <thead>
                <tr>
                  {content.inventory.headers.map((header) => <th>{header}</th>)}
                </tr>
              </thead>
              <tbody>
                {
                  content.inventory.rows.map((row) => (
                    <tr>
                      <td>
                        {row.item} <span class="gloss">({row.gloss})</span>
                      </td>
                      <td>
                        {row.gender} <span class="g-sym">{row.symbol}</span>
                      </td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
            <p class="table-verdict inv-verdict">{content.inventory.verdict}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Group: exhibit — the applicant's reform proposals -->
    <div class="group">
      <ScrollyStep step={3} />
      <div class="stage-col">
        <div class="stage-sticky">
          <div class="stage-card stage-f3">
            <div class="card-head">
              <span>{content.proposals.head.left}</span>
              <span>{content.proposals.head.right}</span>
            </div>
            <ol class="prop-list">
              {
                content.proposals.items.map((item) => (
                  <li value={item.value}>{item.text}</li>
                ))
              }
            </ol>
            <p class="file-meta prop-note">{content.proposals.note}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Group: the German declension table, as found -->
    <div class="group">
      <ScrollyStep step={4} />
      <div class="stage-col">
        <div class="stage-sticky">
          <div class="stage-card stage-de stage-de1">
            <div class="card-head">
              <span>{content.germanArticles.head.left}</span>
              <span>{content.germanArticles.head.right}</span>
            </div>
            <ScrollyTransformTable
              headers={content.germanArticles.headers}
              rows={content.germanArticles.rows}
            />
            <p class="table-verdict de-verdict">{content.germanArticles.verdict}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Group: the Old English declension table -->
    <div class="group">
      <ScrollyStep step={5} />
      <div class="stage-col">
        <div class="stage-sticky">
          <div class="stage-card stage-oe" data-at="6" data-from="5" data-to="6">
            <div class="card-head">
              <span>{content.oldEnglishArticles.head.left}</span>
              <span>{content.oldEnglishArticles.head.right}</span>
            </div>
            <ScrollyTransformTable
              headers={content.oldEnglishArticles.headers}
              rows={content.oldEnglishArticles.rows}
            />
            <p class="table-verdict oe-verdict">
              {content.oldEnglishArticles.verdict}
            </p>
          </div>
        </div>
      </div>
      <div class="group-steps">
        <ScrollyStep step={6} />
      </div>
    </div>

    <!-- Group: the precedent, word by word -->
    <div class="group">
      <ScrollyStep step={7} />
      <div class="stage-col">
        <div class="stage-sticky">
          <div class="stage-card stage-prec">
            <div class="card-head">
              <span>{content.precedent.head.left}</span>
              <span>{content.precedent.head.right}</span>
            </div>
            <table class="prec-table">
              <thead>
                <tr>
                  {content.precedent.headers.map((header) => <th>{header}</th>)}
                </tr>
              </thead>
              <tbody>
                {
                  content.precedent.rows.map((row) => {
                    const [article, ...noun] = row.today.split(" ");
                    return (
                      <tr>
                        <td>
                          {row.old} <span class="gloss">({row.gloss})</span>
                        </td>
                        <td>{row.middle}</td>
                        <td>
                          <ins>{article}</ins> {noun.join(" ")}
                        </td>
                      </tr>
                    );
                  })
                }
              </tbody>
            </table>
            <p class="table-verdict prec-verdict">{content.precedent.verdict}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Group: the German table again, this time collapsing -->
    <div class="group">
      <ScrollyStep step={8} />
      <div class="stage-col">
        <div class="stage-sticky">
          <div class="stage-card stage-de stage-de2" data-at="8" data-from="7" data-to="8">
            <div class="card-head">
              <span>{content.germanArticles.head.left}</span>
              <span>{content.germanArticles.head.right}</span>
            </div>
            <ScrollyTransformTable
              headers={content.germanArticles.headers}
              rows={content.germanArticles.rows}
            />
            <p class="table-verdict de-verdict">{content.germanArticles.verdict}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Group: the sentence under processing -->
    <div class="group">
      <ScrollyStep step={9} />
      <div class="stage-col">
        <div class="stage-sticky">
          <div class="stage-card stage-doc" data-from="9" data-to="14">
            <div class="card-head">
              <span>{content.document.head.left}</span>
              <span>{content.document.head.right}</span>
            </div>
            <p
              class="doc-source"
              set:html={richTextHtml(content.document.source)}
            />
            <p class="doc-sentence">
              {
                content.document.sentence.map((segment) =>
                  typeof segment === "string" ? (
                    segment
                  ) : (
                    <span class="tok" data-at={segment.at}>
                      <del>{segment.from}</del>
                      <ins>{segment.to}</ins>
                    </span>
                  ),
                )
              }
            </p>
            <div class="doc-chips" aria-hidden="true">
              {
                content.document.chips.map((chip) => (
                  <span class="chip" data-at={chip.at}>{chip.text}</span>
                ))
              }
            </div>
            <div class="doc-clean" data-at="14">
              <p class="clean-label">{content.document.cleanLabel}</p>
              <p class="clean-sentence">{content.document.cleanSentence}</p>
            </div>
            <div class="stamp" data-at="14" aria-hidden="true">
              <span class="stamp-emblem"></span>
              <span class="stamp-line1">{content.document.stamp.line1}</span>
              <span class="stamp-line2">{content.document.stamp.line2}</span>
            </div>
          </div>
        </div>
      </div>
      <div class="group-steps">
        <ScrollyStep step={10} />
        <ScrollyStep step={11} />
        <ScrollyStep step={12} />
        <ScrollyStep step={13} />
        <ScrollyStep step={14} />
      </div>
    </div>

    <!-- Group: the world register -->
    <div class="group">
      <ScrollyStep step={15} />
      <div class="stage-col">
        <div class="stage-sticky">
          <div class="stage-card stage-world" data-at="16" data-from="15" data-to="16">
            <div class="card-head">
              <span>{content.world.head.left}</span>
              <span>{content.world.head.right}</span>
            </div>
            <div class="world-map" set:html={worldMap} />
            <div class="world-legend">
              {
                content.world.legend.map((item) => (
                  <p
                    class={`legend-row ${item.className}`}
                    data-at={"at" in item ? item.at : undefined}
                  >
                    <span class={`swatch ${item.swatchClass}`}></span>
                    {item.language} <span class="gloss">({item.gloss})</span>
                  </p>
                ))
              }
            </div>
          </div>
        </div>
      </div>
      <div class="group-steps">
        <ScrollyStep step={16} />
      </div>
    </div>
  </div>
</section>

<script>
  // State is derived from scroll position on every frame rather than from
  // intersection events, so fast flicks and restored scroll positions can
  // never desynchronize it.
  //
  // Wide screens: the step block nearest the reading line drives one global
  // step, which selects the visible card (data-stage) and its inner state.
  //
  // Small screens: the layout is linear (text first, then card); animated
  // cards pin while a scroll runway plays their sub-steps, so the
  // transformation runs under the reader's thumb and rewinds when
  // scrolling back.
  const section = document.getElementById("demo")!;
  const steps = [...section.querySelectorAll<HTMLElement>(".step")];
  const cards = [...section.querySelectorAll<HTMLElement>(".stage-card")];
  const wide = window.matchMedia("(min-width: 861px)");

  const STAGES = [
    "f1", "f1", "f2", "f3",       // Twain file and exhibits
    "de1", "oe", "oe", "prec",    // tables and precedent
    "de2",                        // remedy: German table collapses
    "doc", "doc", "doc", "doc", "doc", "doc", // Kafka processing
    "world", "world",             // statement of purpose
  ];

  // Toggle .done on root and every [data-at] descendant against a step.
  function setDone(root: HTMLElement, step: number) {
    for (const el of [root, ...root.querySelectorAll<HTMLElement>("[data-at]")]) {
      if (el.dataset.at !== undefined) {
        el.classList.toggle("done", step >= Number(el.dataset.at));
      }
    }
  }

  function wideFrame() {
    const line = window.innerHeight * 0.45;
    let step = 0;
    for (const el of steps) {
      if (el.getBoundingClientRect().top <= line) {
        step = Number(el.dataset.step);
      }
    }
    section.dataset.step = String(step);
    section.dataset.stage = STAGES[step] ?? "world";
    setDone(section, step);
  }

  function narrowFrame() {
    // Animated cards pin near the top of the viewport (see .stage-sticky in
    // the narrow media query) while their column's ::after runway scrolls
    // by underneath; progress through the runway drives the sub-steps, so
    // the animation plays over several scrolls with the card fixed, and
    // rewinds when scrolling back.
    const pin = window.innerHeight * 0.08;
    for (const card of cards) {
      if (card.dataset.from === undefined) continue;
      const from = Number(card.dataset.from);
      const to = Number(card.dataset.to);
      const sticky = card.parentElement!;
      const col = sticky.parentElement!;
      const cr = col.getBoundingClientRect();
      const sh = sticky.getBoundingClientRect().height;
      const runway = cr.height - sh;
      let p = 1;
      if (runway > 1) {
        p = Math.min(1, Math.max(0, 1 - (cr.bottom - sh - pin) / runway));
      }
      setDone(card, from + Math.round(p * (to - from)));
    }
  }

  let ticking = false;
  function schedule() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      ticking = false;
      if (wide.matches) {
        wideFrame();
      } else {
        narrowFrame();
      }
    });
  }

  window.addEventListener("scroll", schedule, { passive: true });
  window.addEventListener("resize", schedule, { passive: true });
  schedule();
</script>

<style is:global>
  /* Full-bleed breakout from the 50rem main column */
  .scrolly {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    padding: 1rem 1.25rem 4rem;
  }

  .scrolly-lead {
    max-width: var(--content-width);
    margin: 0 auto 1rem;
    text-align: center;
    padding: 1.5rem 0 0;
  }

  .kicker,
  .step-kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--grey-1);
  }

  .scrolly-lead h2 {
    border: none;
    padding: 0;
    margin: 0.4rem 0 0.3rem;
    font-size: 2.3rem;
  }

  .scrolly-lead .sub {
    margin: 0;
    color: var(--grey-1);
  }

  .scrolly-body {
    max-width: 66rem;
    margin: 0 auto;
    position: relative;
  }

  /* ---------- Stage cards (shared) ---------- */

  .stage-card {
    background: #ffffff;
    border: 1px solid var(--ink);
    border-radius: 2px;
    padding: 1.5rem 1.75rem 1.75rem;
    width: 100%;
    max-width: 34rem;
    position: relative;
  }

  .card-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--grey-1);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 0.55rem;
    margin-bottom: 1.1rem;
  }

  .gloss {
    font-family: var(--font-mono);
    font-weight: 400;
    font-style: normal;
    font-size: 0.72rem;
    color: var(--grey-1);
  }

  /* Case-file stage */
  .file-meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.8;
    color: var(--grey-1);
    margin: 0 0 1.1rem;
  }

  .file-meta strong {
    color: var(--fail-red);
    font-weight: 400;
  }

  .file-quote {
    margin: 0;
    padding: 0;
    border: none;
    color: var(--ink);
    font-style: italic;
    font-size: 1.02rem;
    line-height: 1.75;
  }

  .file-attrib {
    margin: 0.7rem 0 0;
    font-size: 0.85rem;
    color: var(--grey-1);
  }

  .file-annex {
    border-top: 1px solid var(--grey-2);
    margin-top: 1.1rem;
    padding-top: 0.9rem;
    opacity: 0;
    transition: opacity 0.5s ease 0.15s;
  }

  .file-annex.done {
    opacity: 1;
  }

  .annex-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--grey-1);
    margin: 0 0 0.6rem;
  }

  .annex-dialogue p {
    margin: 0 0 0.35rem;
    font-size: 0.95rem;
    font-style: italic;
  }

  .annex-dialogue .speaker {
    font-style: normal;
    font-weight: 600;
  }

  /* Inventory exhibit */
  .inv-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0.25rem 0 0;
  }

  .inv-table th {
    font-family: var(--font-din);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.72rem;
    text-align: left;
    border: none;
    border-bottom: 1px solid var(--ink);
    padding: 0.35rem 0.6rem;
  }

  .inv-table td {
    border-bottom: 1px solid var(--grey-2);
    padding: 0.35rem 0.6rem;
    font-size: 0.95rem;
  }

  .inv-table td:last-child {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--grey-1);
  }

  .g-sym {
    /* ♂ ♀ ⚲ — the gender symbols; system fonts, not the mono stack,
       so U+26B2 NEUTER renders reliably. */
    font-family:
      "Hiragino Sans", "Segoe UI Symbol", "Noto Sans Symbols 2", sans-serif;
    font-size: 0.9rem;
    color: var(--form-blue);
    padding-left: 0.15rem;
  }

  .inv-verdict,
  .prec-verdict {
    opacity: 1;
  }

  /* Proposals exhibit */
  .prop-list {
    margin: 0.25rem 0 0;
    padding-left: 1.5rem;
  }

  .prop-list li {
    font-style: italic;
    font-size: 0.98rem;
    line-height: 1.7;
    margin-bottom: 0.9rem;
  }

  .prop-list li::marker {
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 0.8rem;
    color: var(--grey-1);
  }

  .prop-note {
    margin: 1.1rem 0 0;
    border-top: 1px solid var(--grey-2);
    padding-top: 0.8rem;
  }

  /* Declension tables (German and Old English) */
  .stage-de table,
  .stage-oe table {
    margin: 0.5rem 0 0;
  }

  .stage-de th,
  .stage-oe th {
    border: none;
    font-size: 0.72rem;
    padding: 0.4rem 0.6rem;
  }

  .stage-de tbody th,
  .stage-oe tbody th {
    text-align: left;
    color: var(--grey-1);
    font-weight: 500;
  }

  .stage-de td,
  .stage-oe td {
    border-bottom: 1px solid var(--grey-2);
    padding: 0.5rem 0.6rem;
    font-family: var(--font-din);
    font-weight: 600;
    font-size: 1.35rem;
    width: 21%;
  }

  .stage-de td del,
  .stage-oe td del {
    text-decoration: none;
  }

  .stage-de td del {
    transition: font-size 0.4s ease, opacity 0.4s ease, color 0.4s ease;
  }

  .stage-de td ins,
  .stage-oe td ins {
    display: none;
    text-decoration: none;
    color: var(--form-blue);
  }

  .stage-de td.stays {
    transition: color 0.5s ease;
  }

  .stage-de.done td del {
    font-size: 0.72em;
    text-decoration: line-through;
    text-decoration-color: var(--fail-red);
    text-decoration-thickness: 1.5px;
    color: var(--grey-1);
    opacity: 0.55;
    margin-right: 0.25em;
  }

  .stage-de.done td ins {
    display: inline;
  }

  .stage-de.done td.stays {
    color: var(--form-blue);
  }

  .stage-oe.done td del {
    display: none;
  }

  .stage-oe.done td ins {
    display: inline;
  }

  .table-verdict {
    margin: 1.2rem 0 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--grey-1);
  }

  .de-verdict,
  .oe-verdict {
    opacity: 0;
    transition: opacity 0.5s ease 0.3s;
  }

  .stage-de.done .de-verdict,
  .stage-oe.done .oe-verdict {
    opacity: 1;
  }

  /* Precedent word table */
  .prec-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0.5rem 0 0;
  }

  .prec-table th {
    font-family: var(--font-din);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.72rem;
    text-align: left;
    border: none;
    padding: 0.4rem 0.6rem;
  }

  .prec-table td {
    border-bottom: 1px solid var(--grey-2);
    padding: 0.55rem 0.6rem;
    font-family: var(--font-din);
    font-weight: 600;
    font-size: 1.15rem;
  }

  .prec-table td:nth-child(2) {
    color: var(--grey-1);
  }

  .prec-table td ins {
    text-decoration: none;
    color: var(--form-blue);
  }

  /* Document stage */
  .doc-source {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--grey-1);
    margin: 0 0 1rem;
  }

  .doc-sentence {
    font-size: 1.12rem;
    line-height: 2;
    margin: 0;
  }

  .tok del {
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .tok ins {
    display: none;
    text-decoration: none;
    color: var(--form-blue);
    font-weight: 600;
  }

  .tok.done del {
    text-decoration: line-through;
    text-decoration-color: var(--fail-red);
    text-decoration-thickness: 1.5px;
    opacity: 0.45;
    margin-right: 0.3em;
  }

  .tok.done ins {
    display: inline;
  }

  .doc-chips {
    display: flex;
    gap: 0.5rem;
    margin-top: 1.2rem;
    min-height: 1.6rem;
  }

  .chip {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    border: 1px solid var(--form-blue);
    color: var(--form-blue);
    border-radius: 2px;
    padding: 0.1rem 0.45rem;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .chip.done {
    opacity: 1;
    transform: none;
  }

  .doc-clean {
    border-top: 1px solid var(--grey-2);
    margin-top: 1.2rem;
    padding-top: 1rem;
    padding-right: 9.5rem;
    min-height: 5.5rem;
    opacity: 0;
    transition: opacity 0.5s ease 0.15s;
  }

  .doc-clean.done {
    opacity: 1;
  }

  .clean-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--grey-1);
    margin: 0 0 0.4rem;
  }

  .clean-sentence {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--form-blue);
  }

  /* Stamp */
  .stamp {
    position: absolute;
    right: 1.4rem;
    bottom: 1.1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
