---
// The standalone AlmanBench page, rendered once per locale. Leaderboard
// numbers come from benchmark-results/almanbench-leaderboard.json; prose is
// shared with the Markdown mirrors (Alman copy must stay spec-compliant).
import Base from "../layouts/Base.astro";
import { localeHome, translationsFor, type Locale } from "../i18n/ui";
import {
  almanBenchBibtex,
  almanBenchExample,
  getAlmanBenchCopy,
} from "../lib/almanbench";
import lb from "../../../benchmark-results/almanbench-leaderboard.json";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const translations = translationsFor("almanbench");

const fmtPct = (correct: number, total: number): string => {
  const pct = ((100 * correct) / total).toFixed(1);
  return locale === "en" ? `${pct}%` : `${pct.replace(".", ",")} %`;
};
const fmtInt = (n: number): string =>
  n.toLocaleString(locale === "en" ? "en-US" : "de-DE");

const tierKeys = ["naturalistic", "targeted", "guards", "curated"] as const;

// The bar axis starts a little below the lowest score, not at zero, and
// ends a little above the highest; ticks sit on multiples of five.
const rates = lb.entries.map((e) => (100 * e.acceptance[0]) / e.acceptance[1]);
const axisMin = Math.max(0, 5 * Math.floor((Math.min(...rates) - 2.5) / 5));
const axisMax = Math.min(100, 5 * Math.ceil((Math.max(...rates) + 2.5) / 5));
const axisTicks: number[] = [];
for (let tick = axisMin; tick <= axisMax; tick += 5) axisTicks.push(tick);
const barPct = (rate: number): number =>
  (100 * (rate - axisMin)) / (axisMax - axisMin);
const fmtTick = (tick: number): string =>
  locale === "en" ? `${tick}%` : `${tick} %`;

// Per-model run details, shown as the hover popover on the model name.
const runTip = (entry: (typeof lb.entries)[number]): string =>
  `${entry.route} · Reasoning: ${entry.reasoning} · ${lb.evaluated}`;

const copy = getAlmanBenchCopy(locale);
const example = almanBenchExample;
const bibtex = almanBenchBibtex;
---

<Base
  title="AlmanBench"
  description={copy.description}
  locale={locale}
  translations={translations}
>
  <div class="doc-band">
    <span>Prüfungsergebnisse · Formblatt AL-2</span>
    <span>AlmanBench v0.1 · Stand {lb.evaluated}</span>
  </div>

  <h1>AlmanBench</h1>
  <p>{copy.lead}</p>
  <p>{copy.lead2}</p>

  <nav class="resource-links">
    <a href={lb.dataset}>
      <img src="/assets/icons/hugging-face.svg" alt="" aria-hidden="true" />
      {copy.linkDataset}
    </a>
    <a href={lb.results}>
      <img src="/assets/icons/hugging-face.svg" alt="" aria-hidden="true" />
      {copy.linkResults}
    </a>
    <a href="https://github.com/osolmaz/alman">
      <img src="/assets/icons/github.svg" alt="" aria-hidden="true" />
      {copy.linkGithub}
    </a>
    <a href={`${localeHome(locale)}#spec`}>{copy.linkSpec}</a>
  </nav>

  <h2>{copy.resultsH}</h2>
  <table class="lb-chart">
    <thead>
      <tr>
        <th class="num">Nr.</th>
        <th>{copy.thModel}</th>
        <th class="lb-bar-col">Score ↑</th>
      </tr>
    </thead>
    <tbody>
      {
        lb.entries.map((entry, index) => (
          <tr>
            <td class="num mono">{index + 1}</td>
            <td class={index === 0 ? "lb-best" : undefined}>
              {"modelUrl" in entry ? (
                <a
                  class="lb-model"
                  data-tip={runTip(entry)}
                  href={entry.modelUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <img
                    class="lb-logo"
                    src={`/assets/icons/models/${entry.vendor}.svg`}
                    alt=""
                    aria-hidden="true"
                  />
                  {entry.label}
                </a>
              ) : (
                <span class="lb-model" tabindex="0" data-tip={runTip(entry)}>
                  <img
                    class="lb-logo"
                    src={`/assets/icons/models/${entry.vendor}.svg`}
                    alt=""
                    aria-hidden="true"
                  />
                  {entry.label}
                </span>
              )}
            </td>
            <td class="lb-bar-col">
              <div class="lb-bar">
                <div class="lb-bar-track">
                  <div
                    class="lb-bar-fill"
                    style={`width: ${barPct((100 * entry.acceptance[0]) / entry.acceptance[1])}%`}
                  />
                </div>
                <span
                  class="lb-bar-label"
                  tabindex="0"
                  data-tip={`${entry.acceptance[0]}/${entry.acceptance[1]}`}
                >
                  {fmtPct(entry.acceptance[0], entry.acceptance[1])}
                </span>
              </div>
            </td>
          </tr>
        ))
      }
    </tbody>
    <tfoot>
      <tr class="lb-axis-row">
        <td />
        <td />
        <td class="lb-bar-col">
          <div class="lb-bar">
            <div class="lb-axis">
              {
                axisTicks.map((tick) => (
                  <span
                    class="lb-axis-tick"
                    style={`left: ${barPct(tick)}%`}
                  >
                    {fmtTick(tick)}
                  </span>
                ))
              }
            </div>
            <span class="lb-bar-label lb-axis-pad" />
          </div>
        </td>
      </tr>
    </tfoot>
  </table>

  <h3>{copy.tiersH}</h3>
  <table>
    <thead>
      <tr>
        <th>{copy.thModel}</th>
        {tierKeys.map((tier) => <th class="num">{tier}</th>)}
      </tr>
    </thead>
    <tbody>
      {
        lb.entries.map((entry) => (
          <tr>
            <td>{entry.label}</td>
            {tierKeys.map((tier) => (
              <td class="num mono">
                <span
                  tabindex="0"
                  data-tip={`${entry.tiers[tier][0]}/${entry.tiers[tier][1]}`}
                >
                  {fmtPct(entry.tiers[tier][0], entry.tiers[tier][1])}
                </span>
              </td>
            ))}
          </tr>
        ))
      }
    </tbody>
  </table>

  <h2>{copy.compH}</h2>
  <p>{copy.compP}</p>
  <table>
    <thead>
      <tr>
        <th>{copy.compTh[0]}</th>
        <th class="num">{copy.compTh[1]}</th>
        <th>{copy.compTh[2]}</th>
      </tr>
    </thead>
    <tbody>
      {
        copy.compRows.map(([tier, count, purpose]) => (
          <tr>
            <td class="mono">{tier}</td>
            <td class="num mono">{fmtInt(count as number)}</td>
            <td>{purpose}</td>
          </tr>
        ))
      }
    </tbody>
  </table>

  <h2>{copy.exampleH}</h2>
  <p set:html={copy.exampleIntro.replace(/\*([^*]+)\*/g, "<i>$1</i>")} />
  <figure class="bench-example">
    <div class="bench-example-id">{example.id}</div>
    <dl>
      <dt>{copy.exampleSrc}</dt>
      <dd>{example.source}</dd>
      <dt>{copy.exampleAccepted}</dt>
      {
        example.accepted.map((rendering, index) => (
          <dd>
            {rendering}
            {index === 0 && <span class="bench-canonical"> ({copy.canonicalMark})</span>}
          </dd>
        ))
      }
    </dl>
  </figure>

  <h2>{copy.runH}</h2>
  <p>{copy.runP}</p>
  <pre><code>from datasets import load_dataset

ds = load_dataset("osolmaz/almanbench", split="test")</code></pre>
  <pre><code>uv run inspect eval alman/bench/task.py --model openai/gpt-5-codex</code></pre>

  <h2>{copy.citeH}</h2>
  <pre><code>{bibtex}</code></pre>
</Base>
