---
import "@fontsource/barlow-semi-condensed/500.css";
import "@fontsource/barlow-semi-condensed/600.css";
import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/400-italic.css";
import "@fontsource/ibm-plex-sans/600.css";
import "@fontsource/ibm-plex-mono/400.css";
import "katex/dist/katex.min.css";
import "../styles/global.css";
import {
  langCodes,
  localeHome,
  localeNames,
  localePrefix,
  localeShort,
  locales,
  ui,
  type Locale,
} from "../i18n/ui";
import { mdPath } from "../lib/markdown-url";
import { DEFAULT_OG_PATH, ogPath } from "../lib/og-path";

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  /** Locales this page exists in, mapped to their paths (for hreflang). */
  translations?: Partial<Record<Locale, string>>;
  /** Whether this page has a raw Markdown mirror and machine-readable indexes. */
  machineReadable?: boolean;
  ogType?: "website" | "article";
  ogImage?: string;
  datePublished?: Date;
  dateModified?: Date;
  author?: string;
}

const {
  title,
  description = "A Simplified German Dialect",
  locale = "en",
  translations,
  machineReadable = true,
  ogType = "website",
  ogImage,
  datePublished,
  dateModified,
  author,
} = Astro.props;
const pageTitle = title ? `${title} | Alman Institut` : "Alman Institut";
const currentPath = Astro.url.pathname;
const canonical = new URL(currentPath, Astro.site).toString();
const imagePath = ogImage ?? (machineReadable ? ogPath(currentPath) : DEFAULT_OG_PATH);
const imageUrl = new URL(imagePath, Astro.site).toString();
const ogLocales: Record<Locale, string> = {
  en: "en_US",
  de: "de_DE",
  al: "de_AL",
};
const structuredData = {
  "@context": "https://schema.org",
  "@type": ogType === "article" ? "BlogPosting" : "WebPage",
  name: title ?? "Alman Institut",
  headline: title ?? "Alman Institut",
  description,
  url: canonical,
  inLanguage: langCodes[locale],
  image: imageUrl,
  ...(author ? { author: { "@type": "Person", name: author } } : {}),
  ...(datePublished ? { datePublished: datePublished.toISOString() } : {}),
  ...(datePublished || dateModified
    ? { dateModified: (dateModified ?? datePublished)?.toISOString() }
    : {}),
  publisher: {
    "@type": "Organization",
    name: "Alman Institut für Sprachvereinfachung",
    url: new URL("/", Astro.site).toString(),
  },
};
const t = ui[locale];

const homePath = localeHome(locale);
const aboutPath = `${localePrefix(locale)}/about/`;
const blogPath = `${localePrefix(locale)}/blog/`;
const benchmarkPath = `${localePrefix(locale)}/almanbench/`;
const navItems = [
  { href: `${homePath}#spec`, label: t["nav.spec"], match: homePath },
  { href: benchmarkPath, label: t["nav.benchmark"], match: benchmarkPath },
  { href: blogPath, label: t["nav.blog"], match: blogPath },
  { href: aboutPath, label: t["nav.about"], match: aboutPath },
];

// Global language switcher: on translated pages it links to the sibling
// language versions; on untranslated pages it falls back to the locale
// home page (the localized specification).
const switcherTarget = (loc: Locale): string =>
  translations?.[loc] ?? localeHome(loc);
---

<!doctype html>
<html lang={langCodes[locale]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title ?? "Alman Institut"} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Alman Institut" />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocales[locale]} />
    {
      translations &&
        Object.keys(translations)
          .filter((loc) => loc !== locale)
          .map((loc) => (
            <meta property="og:locale:alternate" content={ogLocales[loc as Locale]} />
          ))
    }
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title ?? "Alman Institut"} />
    {datePublished && <meta property="article:published_time" content={datePublished.toISOString()} />}
    {(dateModified || datePublished) && <meta property="article:modified_time" content={(dateModified ?? datePublished)?.toISOString()} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title ?? "Alman Institut"} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={title ?? "Alman Institut"} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Alman Institut" href="/feed.xml" />
    <link rel="canonical" href={canonical} />
    {
      machineReadable && (
        <>
          <link rel="alternate" type="text/markdown" href={mdPath(currentPath)} />
          <link rel="alternate" type="text/plain" href="/llms.txt" />
          <link rel="alternate" type="text/plain" href="/llms-full.txt" />
        </>
      )
    }
    {
      translations &&
        Object.entries(translations).map(([loc, path]) => (
          <link
            rel="alternate"
            hreflang={langCodes[loc as Locale]}
            href={new URL(path, Astro.site)}
          />
        ))
    }

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BDXXJLP8RP"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-BDXXJLP8RP");
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="inner">
        <a class="site-brand" href="/">
          <img
            src="/assets/brand/alman_institut_lockup.svg"
            alt="Alman Institut für Sprachvereinfachung"
          />
        </a>
        <nav class="site-nav">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                aria-current={
                  (item.match === homePath
                    ? currentPath === homePath
                    : currentPath.startsWith(item.match))
                    ? "page"
                    : undefined
                }
              >
                {item.label}
              </a>
            ))
          }
          <span class="lang-nav" role="group" aria-label="Sprachfassung">
            {
              locales.map((loc) =>
                loc === locale ? (
                  <span
                    class="lang-nav-current"
                    aria-current="true"
                    title={localeNames[loc]}
                  >
                    {localeShort[loc]}
                  </span>
                ) : (
                  <a
                    href={switcherTarget(loc)}
                    title={localeNames[loc]}
                    lang={langCodes[loc]}
                  >
                    {localeShort[loc]}
                  </a>
                ),
              )
            }
          </span>
        </nav>
      </div>
    </header>
    <div class="flag-rule" aria-hidden="true"><span></span><span></span><span></span></div>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="inner">
        <span>Alman Institut für Sprachvereinfachung</span>
        <span>
          <a href="https://github.com/osolmaz/alman">GitHub</a> ·
          <a href="/feed.xml">RSS</a>
        </span>
      </div>
    </footer>
  </body>
</html>
