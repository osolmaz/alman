{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://huggingface.co/datasets/osolmaz/alman/blob/main/benchmark-results/almanbench-results/almanbench-result.schema.json",
  "title": "AlmanBench sample result",
  "description": "One normalized model result for one curated Alman benchmark case.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_id",
    "case_set_id",
    "case_set_size",
    "scoring_revision",
    "sample_id",
    "collection",
    "source",
    "accepted",
    "model_id",
    "model_label",
    "model_name",
    "reasoning_effort",
    "platform",
    "backend",
    "model_revision",
    "output",
    "reasoning",
    "reasoning_summary",
    "reasoning_status",
    "correct",
    "compliant",
    "thinking_observed",
    "forced_final",
    "response_id",
    "returned_model",
    "finish_reason",
    "completed_at",
    "uncached_input_tokens",
    "cached_input_tokens",
    "cache_creation_input_tokens",
    "output_tokens",
    "reasoning_tokens",
    "total_tokens",
    "run_id",
    "execution_id",
    "artifact"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "benchmark_id": {"type": "string", "minLength": 1},
    "case_set_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "case_set_size": {"type": "integer", "minimum": 1},
    "scoring_revision": {"type": "string", "minLength": 1},
    "sample_id": {"type": "string", "minLength": 1},
    "collection": {"type": "string", "minLength": 1},
    "source": {"type": "string", "minLength": 1},
    "accepted": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "model_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "model_label": {"type": "string", "minLength": 1},
    "model_name": {
      "type": "string",
      "minLength": 1,
      "description": "Requested API model ID or canonical model repository."
    },
    "reasoning_effort": {
      "type": ["string", "null"],
      "enum": [null, "none", "minimal", "low", "medium", "high", "xhigh", "max"],
      "description": "Requested reasoning effort, or null when the model profile does not expose one."
    },
    "platform": {
      "enum": [
        "openai-api",
        "anthropic-api",
        "huggingface-inference-providers",
        "huggingface-inference-endpoint",
        "local"
      ]
    },
    "backend": {"type": "string", "minLength": 1},
    "model_revision": {"type": ["string", "null"]},
    "output": {"type": "string"},
    "reasoning": {"type": ["string", "null"]},
    "reasoning_summary": {"type": ["string", "null"]},
    "reasoning_status": {
      "enum": ["returned", "redacted", "not_exposed", "not_observed"]
    },
    "correct": {"type": "boolean"},
    "compliant": {"type": "boolean"},
    "thinking_observed": {"type": "boolean"},
    "forced_final": {"type": "boolean"},
    "response_id": {"type": ["string", "null"]},
    "returned_model": {"type": ["string", "null"]},
    "finish_reason": {"type": ["string", "null"]},
    "completed_at": {"type": ["string", "null"], "format": "date-time"},
    "uncached_input_tokens": {"type": "integer", "minimum": 0},
    "cached_input_tokens": {"type": "integer", "minimum": 0},
    "cache_creation_input_tokens": {"type": "integer", "minimum": 0},
    "output_tokens": {"type": "integer", "minimum": 0},
    "reasoning_tokens": {"type": ["integer", "null"], "minimum": 0},
    "total_tokens": {"type": "integer", "minimum": 0},
    "run_id": {
      "type": "string",
      "minLength": 1,
      "description": "Logical model run; may combine multiple executions that filled missing cases."
    },
    "execution_id": {
      "type": "string",
      "minLength": 1,
      "description": "Physical API or local execution that produced this row."
    },
    "artifact": {"type": "string", "minLength": 1}
  }
}
