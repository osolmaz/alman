{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["section_numbers", "paragraph_numbers", "rule_letters"],
  "properties": {
    "section_numbers": {
      "type": "object",
      "description": "Maps section ids to their stable section numbers",
      "patternProperties": {
        "^[a-z0-9-]+$": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "paragraph_numbers": {
      "type": "object",
      "description": "Maps paragraph ids to their stable global paragraph numbers",
      "patternProperties": {
        "^[a-z0-9-]+$": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "rule_letters": {
      "type": "object",
      "description": "Maps 'paragraph-id/rule-id' keys to their stable rule letters within the paragraph",
      "patternProperties": {
        "^[a-z0-9-]+/[a-z0-9-]+$": {
          "type": "string",
          "pattern": "^[a-z]$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
