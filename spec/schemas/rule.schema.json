{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "title", "description"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Slugified identifier for the rule"
    },
    "title": {
      "type": "string",
      "description": "Title of the rule"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the rule"
    },
    "i18n": {
      "type": "object",
      "description": "Translations of prose fields, keyed by locale (de, al)",
      "properties": {
        "de": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "al": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" }
          }
        }
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["standard", "alman"],
        "properties": {
          "standard": {
            "type": "string",
            "description": "Standard German example"
          },
          "alman": {
            "type": "string",
            "description": "Alman German example"
          }
        }
      }
    }
  }
}