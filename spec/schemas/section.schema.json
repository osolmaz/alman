{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "title", "body", "paragraphs"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Slugified identifier for the section"
    },
    "title": {
      "type": "string",
      "description": "Title of the section"
    },
    "body": {
      "type": "string",
      "description": "Description or content of the section"
    },
    "i18n": {
      "type": "object",
      "description": "Translations of prose fields, keyed by locale (de, al)",
      "properties": {
        "de": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "body": { "type": "string" }
          }
        },
        "al": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "body": { "type": "string" }
          }
        }
      }
    },
    "paragraphs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Slugified identifier for the paragraph"
          }
        }
      }
    }
  }
}