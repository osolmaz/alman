---
import { getEntry, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import { translationsFor } from "../../i18n/ui";

const entry = await getEntry("about", "de");
if (!entry) throw new Error("About entry 'de' not found.");
const { Content } = await render(entry);
const translations = translationsFor("about");
---

<Base title={entry.data.title} locale="de" translations={translations}>
  <h1>{entry.data.title}</h1>
  <Content />
</Base>
