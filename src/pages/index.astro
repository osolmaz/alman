---
import { getEntry, render } from "astro:content";
import Base from "../layouts/Base.astro";
import specMeta from "../../spec/main.json";

const entry = await getEntry("spec", "spec");
if (!entry) {
  throw new Error(
    "Spec document not found. Generate it with `uv run python -m alman.build`.",
  );
}
const { Content } = await render(entry);
---

<Base title="Specification" description="The Alman specification: a simplified German dialect.">
  <div class="doc-band">
    <span>Amtliche Fassung</span>
    <span>Dokument AL-1 · Stand {specMeta.lastUpdated}</span>
  </div>
  <article class="spec-doc">
    <Content />
  </article>
  <hr />
  <p>
    The Alman specification is open source and can be edited on
    <a href="https://github.com/osolmaz/alman">GitHub</a>.
  </p>
</Base>
