---
// A slim, form-style language switcher for pages that exist in several
// language versions ("Sprachfassungen").
import { localeNames, type Locale } from "../i18n/ui";

interface Props {
  locale: Locale;
  translations: Partial<Record<Locale, string>>;
}

const { locale, translations } = Astro.props;
const entries = Object.entries(translations) as [Locale, string][];
---

<nav class="lang-switcher" aria-label="Language versions">
  <span class="lang-label">Sprachfassung</span>
  {
    entries.map(([loc, path]) =>
      loc === locale ? (
        <span class="lang-current" aria-current="true">
          {localeNames[loc]}
        </span>
      ) : (
        <a href={path}>{localeNames[loc]}</a>
      ),
    )
  }
</nav>

<style>
  .lang-switcher {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid var(--grey-2);
    background: #ffffff;
    padding: 0.5rem 0.9rem;
    margin: 0 0 1.8rem;
  }

  .lang-label {
    color: var(--grey-1);
    margin-right: auto;
  }

  .lang-switcher a {
    color: var(--form-blue);
    text-decoration: none;
  }

  .lang-switcher a:hover {
    text-decoration: underline;
  }

  .lang-current {
    font-weight: 600;
  }
</style>
