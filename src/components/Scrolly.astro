    -webkit-mask: url("/assets/brand/alman_institut_logo.svg") no-repeat center / contain;
    mask: url("/assets/brand/alman_institut_logo.svg") no-repeat center / contain;
  }

  .stamp-line1 {
    font-family: var(--font-din);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
