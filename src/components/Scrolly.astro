    .stage-card {
      padding: 0.85rem 1rem 1rem;
    }

    .card-head {
      font-size: 0.58rem;
      letter-spacing: 0.06em;
      padding-bottom: 0.45rem;
      margin-bottom: 0.8rem;
    }

    .card-head span {
      white-space: nowrap;
    }

    .file-meta {
      font-size: 0.66rem;
      margin-bottom: 0.8rem;
    }

    .file-quote {
      font-size: 0.92rem;
      line-height: 1.65;
    }

    .file-attrib {
      font-size: 0.78rem;
      margin-top: 0.5rem;
    }

    .file-annex {
      margin-top: 0.8rem;
      padding-top: 0.7rem;
    }

    .annex-dialogue p {
      font-size: 0.86rem;
    }

    .stage-table td {
      font-size: 1.05rem;
    }

    .prec-table td {
      font-size: 1rem;
    }

    .doc-source {
      font-size: 0.64rem;
      margin-bottom: 0.7rem;
    }

    .doc-sentence {
