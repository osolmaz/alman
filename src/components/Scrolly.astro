    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 0.72rem;
    color: var(--grey-1);
  }

  .prec-verdict {
    opacity: 1;
  }

  /* Document stage */
  .doc-source {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--grey-1);
    margin: 0 0 1rem;
  }

  .doc-sentence {
    font-size: 1.12rem;
    line-height: 2;
    margin: 0;
  }

  .tok del {
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .tok ins {
    display: none;
    text-decoration: none;
    color: var(--form-blue);
    font-weight: 600;
  }

  .tok.done del {
    text-decoration: line-through;
    text-decoration-color: var(--fail-red);
    text-decoration-thickness: 1.5px;
    opacity: 0.45;
    margin-right: 0.3em;
  }

  .tok.done ins {
    display: inline;
  }

  .doc-chips {
    display: flex;
    gap: 0.5rem;
    margin-top: 1.2rem;
    min-height: 1.6rem;
  }

  .chip {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    border: 1px solid var(--form-blue);
    color: var(--form-blue);
    border-radius: 2px;
    padding: 0.1rem 0.45rem;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .chip.done {
    opacity: 1;
    transform: none;
  }

  .doc-clean {
    border-top: 1px solid var(--grey-2);
    margin-top: 1.2rem;
    padding-top: 1rem;
    padding-right: 9.5rem;
    min-height: 5.5rem;
    opacity: 0;
    transition: opacity 0.5s ease 0.15s;
  }

  .doc-clean.done {
    opacity: 1;
  }

  .clean-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--grey-1);
    margin: 0 0 0.4rem;
  }

  .clean-sentence {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--form-blue);
  }

  /* Stamp */
  .stamp {
    position: absolute;
    right: 1.4rem;
    bottom: 1.1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    padding: 0.6rem 1rem 0.7rem;
    border: 2.5px solid var(--form-blue);
    border-radius: 4px;
    box-shadow: inset 0 0 0 1.5px #ffffff, inset 0 0 0 2.5px var(--form-blue);
    color: var(--form-blue);
    transform: rotate(-8deg) scale(1.6);
    opacity: 0;
    transition: opacity 0.25s ease, transform 0.25s cubic-bezier(0.2, 1.4, 0.4, 1);
    pointer-events: none;
